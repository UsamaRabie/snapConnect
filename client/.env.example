# ──────────────────────────────────────────────
# SnapConnect Client - Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env.local and fill in your values
# ──────────────────────────────────────────────

# API URL - Your backend server URL
# For local development:
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
# For production (Render):
# NEXT_PUBLIC_API_URL=https://your-app-name.onrender.com/api/v1

# Site URL - Used for SEO metadata and sitemap
# For local development:
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# For production (Vercel):
# NEXT_PUBLIC_BASE_URL=https://snapconnect.vercel.app
