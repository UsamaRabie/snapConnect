# ─── Client ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1

# ─── Server ───────────────────────────────────────────
NODE_ENV=development
PORT=5000

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/snapconnect?retryWrites=true&w=majority

# JWT Secrets (use openssl rand -hex 32 to generate)
JWT_ACCESS_SECRET=change-me-to-a-random-64-char-hex-string
JWT_REFRESH_SECRET=change-me-to-another-random-64-char-hex-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
