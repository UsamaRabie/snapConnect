# ──────────────────────────────────────────────
# SnapConnect Server - Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=5000

# MongoDB
# Replace <password> with your MongoDB Atlas password
# Replace <cluster> with your cluster name
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/snapconnect?retryWrites=true&w=majority

# JWT - Use strong random secrets (min 32 characters each)
# Generate via: openssl rand -base64 32
JWT_ACCESS_SECRET=your-access-secret-key-min-32-chars-long
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cloudinary (required for image uploads)
# Get these from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# CORS
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
